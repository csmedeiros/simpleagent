# =============================================================================
# Configuração do Modelo (obrigatório)
# =============================================================================
# URL base da API compatível com OpenAI (OpenAI, Azure OpenAI, OpenRouter, etc)
MODEL_BASE_URL="https://api.openai.com/v1"

# API key do provedor
MODEL_API_KEY="sua-api-key-aqui"

# Se usar OpenAI diretamente (ao invés de MODEL_BASE_URL/MODEL_API_KEY),
# pode usar a variável padrão:
# OPENAI_API_KEY="sk-..."
